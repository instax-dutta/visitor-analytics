{
  "title": "Visitor Analytics — Backend",
  "uid": "visitor-analytics-backend",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Ingest batches (by status)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (rate(va_ingest_batches_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Records ingested / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(rate(va_ingest_records_total{status=\"accepted\"}[5m]))", "legendFormat": "accepted" }
      ]
    },
    {
      "id": 3,
      "title": "Auth failures / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (reason) (rate(va_auth_failures_total[5m]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Invalid payloads / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "rate(va_invalid_payloads_total[5m])", "legendFormat": "invalid" }]
    },
    {
      "id": 5,
      "title": "DB query latency p95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(va_db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "GDPR deletions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (status) (rate(va_gdpr_deletions_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ]
}
