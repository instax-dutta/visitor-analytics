# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Storage: "postgres" or "memory". When DATABASE_URL is set and STORAGE is
# omitted, postgres is selected automatically.
STORAGE=memory
DATABASE_URL=postgresql://visitor:visitor@localhost:5432/visitor_analytics

# Authentication. Comma-separated list of valid API keys. Clients send these
# via the X-API-Key header (or Authorization: Bearer <key>).
API_KEYS=va_test_key_1,va_test_key_2

# Optional HMAC request signing. When HMAC_SECRET is set, clients must sign the
# raw request body with HMAC-SHA256 and send it via the X-Signature header.
HMAC_SECRET=

# Security
CORS_ORIGIN=*
TRUST_PROXY=1

# Rate limiting (per IP, sliding window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600

# Data retention (days). Records older than this are purged by the retention job.
RETENTION_DAYS=365

# Public base URL used in API responses / docs
PUBLIC_BASE_URL=http://localhost:3000
