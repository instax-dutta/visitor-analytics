{
  "name": "@visitor-analytics-sdk/utils",
  "description": "Shared utilities for the visitor-analytics SDK — ID generation, browser detection, idle callbacks, SDK versioning, and type definitions.",
  "license": "MIT",
  "keywords": ["visitor-analytics", "utilities", "helpers", "typescript", "sdk"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/instax-dutta/visitor-analytics.git"
  },
  "homepage": "https://github.com/instax-dutta/visitor-analytics#readme",
  "bugs": {
    "url": "https://github.com/instax-dutta/visitor-analytics/issues"
  },
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --treeshake",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0"
  }
}
