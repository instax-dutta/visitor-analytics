{
  "name": "@visitor-analytics-sdk/framework",
  "description": "Framework integration shims for the visitor-analytics SDK — React, Vue, Svelte, SolidJS, and Astro providers, hooks, and stores.",
  "license": "MIT",
  "keywords": ["visitor-analytics", "react", "vue", "svelte", "solidjs", "astro", "framework"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/instax-dutta/visitor-analytics.git"
  },
  "homepage": "https://github.com/instax-dutta/visitor-analytics#readme",
  "bugs": {
    "url": "https://github.com/instax-dutta/visitor-analytics/issues"
  },
  "version": "1.0.1",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue/index.js",
      "types": "./dist/vue/index.d.ts"
    },
    "./svelte": {
      "import": "./dist/svelte/index.js",
      "types": "./dist/svelte/index.d.ts"
    },
    "./solid": {
      "import": "./dist/solid/index.js",
      "types": "./dist/solid/index.d.ts"
    },
    "./astro": {
      "import": "./dist/astro/index.js",
      "types": "./dist/astro/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --format esm --dts --treeshake",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@visitor-analytics-sdk/core": "workspace:*",
    "@visitor-analytics-sdk/utils": "workspace:*"
  },
  "peerDependencies": {
    "@visitor-analytics-sdk/core": ">=1.0.0",
    "react": ">=17.0.0",
    "solid-js": ">=1.0.0",
    "svelte": ">=4.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@visitor-analytics-sdk/core": {
      "optional": false
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17"
  }
}
