{
  "name": "@visitor-analytics-sdk/uploader",
  "description": "Batch uploader for the visitor-analytics SDK — configurable batching, exponential backoff retry, request deduplication, and compression.",
  "license": "MIT",
  "keywords": ["visitor-analytics", "uploader", "batch", "retry", "deduplication", "compression"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/instax-dutta/visitor-analytics.git"
  },
  "homepage": "https://github.com/instax-dutta/visitor-analytics#readme",
  "bugs": {
    "url": "https://github.com/instax-dutta/visitor-analytics/issues"
  },
  "version": "1.0.1",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --treeshake",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@visitor-analytics-sdk/core": "workspace:*",
    "@visitor-analytics-sdk/utils": "workspace:*"
  }
}
